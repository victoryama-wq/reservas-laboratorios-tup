rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function currentUserDoc() {
      return userDoc(request.auth.uid);
    }

    function hasValidRole() {
      return currentUserDoc().data.role in [
        'docente',
        'responsable_laboratorio',
        'admin_sistemas',
      ];
    }

    function isActiveUser() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserDoc().data.active == true
        && hasValidRole();
    }

    function hasRole(role) {
      return isActiveUser() && currentUserDoc().data.role == role;
    }

    function isAdmin() {
      return hasRole('admin_sistemas');
    }

    function isResponsibleForLab(labId) {
      return hasRole('responsable_laboratorio')
        && currentUserDoc().data.labsAssigned is list
        && labId in currentUserDoc().data.labsAssigned;
    }

    function isReservationOwner() {
      return isActiveUser() && resource.data.teacherUid == request.auth.uid;
    }

    match /users/{uid} {
      allow get: if isOwner(uid) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /labs/{labId} {
      allow get, list: if isAdmin();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /reservations/{reservationId} {
      allow get, list: if isAdmin()
        || isReservationOwner()
        || isResponsibleForLab(resource.data.labId);
      allow create, update, delete: if false;
    }

    match /reservationLogs/{logId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /preauthorizedUsers/{emailKey} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /systemSettings/{settingId} {
      allow get, list, create, update: if isAdmin();
      allow delete: if false;
    }

    match /blockedPeriods/{blockedPeriodId} {
      allow get, list: if isActiveUser();
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    match /auditEvents/{auditEventId} {
      allow get, list: if isAdmin();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
